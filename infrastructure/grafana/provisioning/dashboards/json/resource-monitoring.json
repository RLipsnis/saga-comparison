      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{name=~\"saga-temporal|saga-rabbitmq|saga-postgres\"}[30s]) * 100",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Container Memory Usage (MB)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
